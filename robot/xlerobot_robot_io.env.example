# Copy to robot/xlerobot_robot_io.env on the robot computer and edit.
#
# Robot-side design:
# - No ROS 2, no DDS, no Nav2/SLAM/Foxglove on the Raspberry Pi.
# - Hardware I/O talks internally through direct fast ZMQ.
# - The optional ros_bridge adapter wraps fast ZMQ as rosbridge topics.
# - The compute PC runs ./run_multisession_slam.sh hardware.

# Compute PC rosbridge endpoint.
# These can be overridden at launch time by the compute PC SSH launcher.
ROSBRIDGE_HOST=192.168.0.10
ROSBRIDGE_PORT=9090
# Alternative single URI form:
# ROSBRIDGE_URI=ws://192.168.0.10:9090

# Tiny Python venv used by run_xlerobot_rosbridge_io.sh.
XLE_ROBOT_VENV=/home/pi/xlerobot-io-venv
LEROBOT_ROOT=/home/pi/lerobot
USE_VENV=true

# Runtime toggles.
ENABLE_BASE=true
ENABLE_LIDAR=true
TELEOP_CAMERA_FEEDS=head,left,right
# depth sensor feeds the compute PC through binary RGB-D and optional IMU topics.
ENABLE_DEPTH_SENSOR=true
# Generic webcam fallback. Leave off when depth sensor color is enabled.
ENABLE_CAMERA=false
DRY_RUN=false

# Direct low-latency ZMQ ports for web/VR/validation clients.
# Commands arrive on PULL, sensors stream on PUB, health/topic queries use REP.
# ENABLE_FAST_ZMQ is kept for older launchers; current hardware I/O always uses it.
ENABLE_FAST_ZMQ=true
FAST_ZMQ_BIND_HOST=0.0.0.0
FAST_ZMQ_PUB_PORT=8855
FAST_ZMQ_PULL_PORT=8856
FAST_ZMQ_REP_PORT=8857
FAST_ZMQ_ROBOT_ID=0
FAST_ZMQ_PUB_HWM=4
FAST_ZMQ_PULL_HWM=1
FAST_ZMQ_WEB_LINEAR_SPEED_MPS=0.2
FAST_ZMQ_WEB_STRAFE_SPEED_MPS=0.2
FAST_ZMQ_WEB_YAW_SPEED_DEGPS=60

# ROS 2 topic conversion is done off-board by the compute PC's indory_pi_bridge,
# which connects to the fast ZMQ sockets directly. This repo no longer ships an
# in-repo rosbridge adapter.

# Old indory_isaac_sim compatibility gateway. Leave disabled with the direct
# fast ZMQ runtime because it binds the same 8855/8856/8857 ports.
START_ISAAC_COMPAT_GATEWAY=false
ISAAC_COMPAT_BIND_HOST=127.0.0.1
ISAAC_COMPAT_PUB_PORT=8855
ISAAC_COMPAT_PULL_PORT=8856
ISAAC_COMPAT_REP_PORT=8857
ISAAC_COMPAT_ROBOT_ID=0
# Keep false unless a caller explicitly sends Feetech raw ticks with
# arm_joint_pos_target_units=feetech_ticks. Canonical Isaac joint positions are
# rad/m and are rejected by the gateway for hardware safety. When enabled, the
# gateway reorders canonical right,left,head ticks into local left,right,head
# order before publishing.
ISAAC_COMPAT_ALLOW_RAW_JOINT_TARGETS=false

# Topic contract with the compute PC.
CMD_TOPIC=/xlerobot/cmd_vel
JOINT_TARGET_TOPIC=/xlerobot/teleop/joint_targets
JOINT_STATES_TOPIC=/xlerobot/joint_states
SCAN_TOPIC=/xlerobot/scan
STATUS_TOPIC=/xlerobot/io_status
CAMERA_TOPIC=/xlerobot/base_camera/image/compressed
CAMERA_INFO_TOPIC=/xlerobot/base_camera/camera_info
CAMERA_FRAME=base_camera_optical_frame
DEPTH_SENSOR_DEPTH_TOPIC=/xlerobot/head_camera/depth/image
DEPTH_SENSOR_DEPTH_CAMERA_INFO_TOPIC=/xlerobot/head_camera/depth/camera_info
DEPTH_SENSOR_COLOR_TOPIC=/xlerobot/head_camera/color/image
DEPTH_SENSOR_COLOR_CAMERA_INFO_TOPIC=/xlerobot/head_camera/color/camera_info
DEPTH_SENSOR_IMU_TOPIC=/xlerobot/head_camera/imu

# Feetech motor buses, matching upstream XLeRobot.
# bus1 / port1: left arm ID 1..6, head pan/tilt ID 7,8.
# bus2 / port2: right arm ID 1..6, 3-wheel holonomic base ID 7,8,9.
XLEROBOT_ID=indoory_fast
XLEROBOT_PORT1=/dev/ttyACM0
XLEROBOT_PORT2=/dev/ttyACM1
BASE_WHEEL_RADIUS_M=0.05
BASE_RADIUS_M=0.125
BASE_LEFT_SIGN=1.0
BASE_BACK_SIGN=1.0
BASE_RIGHT_SIGN=1.0
BASE_MAX_RAW_COMMAND=3000
BASE_COMMAND_RATE_HZ=200.0
BASE_FEEDBACK_RATE_HZ=20.0
JOINT_COMMAND_RATE_HZ=50.0
JOINT_STATE_RATE_HZ=20.0
BASE_WATCHDOG_TIMEOUT_S=0.3
BASE_RECONNECT_DELAY_S=2.0
# Fast ZMQ publishes odom when enabled; ros_bridge can wrap it as /xlerobot/odom.
BASE_PUBLISH_ODOM=false
BASE_USE_FEEDBACK_ODOM=true
BASE_DISABLE_TORQUE_ON_SHUTDOWN=false
ODOM_FRAME=odom
BASE_FRAME=base_link

# RPLIDAR C-series.
LIDAR_SERIAL=/dev/serial/by-id/usb-Silicon_Labs_CP2102N_USB_to_UART_Bridge_Controller_12703f59806eef11ba3ee8c2c169b110-if00-port0
LIDAR_BAUD=460800
LIDAR_FRAME=laser
# 360 bins is easier on Pi/network and enough for initial SLAM/Nav.
LIDAR_SAMPLES=360
LIDAR_PUBLISH_RATE_HZ=10
LIDAR_ANGLE_OFFSET_DEG=0.0
LIDAR_INVERT=false
LIDAR_RANGE_MIN=0.12
LIDAR_RANGE_MAX=12.0
LIDAR_MIN_QUALITY=0
LIDAR_MIN_POINTS_PER_ROTATION=30

# Depth sensor.
# Leave DEPTH_SENSOR_SERIAL empty to use the first connected depth sensor SDK device.
DEPTH_SENSOR_SERIAL=
DEPTH_SENSOR_DEPTH_WIDTH=640
DEPTH_SENSOR_DEPTH_HEIGHT=360
DEPTH_SENSOR_DEPTH_FPS=15
DEPTH_SENSOR_ENABLE_COLOR=true
DEPTH_SENSOR_COLOR_WIDTH=640
DEPTH_SENSOR_COLOR_HEIGHT=360
DEPTH_SENSOR_COLOR_FPS=15
DEPTH_SENSOR_DEPTH_PUBLISH_HZ=15
DEPTH_SENSOR_COLOR_PUBLISH_HZ=15
DEPTH_SENSOR_ALIGN_DEPTH_TO_COLOR=true
DEPTH_SENSOR_JPEG_QUALITY=80
DEPTH_SENSOR_PNG_COMPRESS_LEVEL=1
DEPTH_SENSOR_ENABLE_IMU=true
DEPTH_SENSOR_IMU_PUBLISH_HZ=100
DEPTH_SENSOR_DEPTH_FRAME=head_camera_depth_optical_frame
DEPTH_SENSOR_COLOR_FRAME=head_camera_color_optical_frame
DEPTH_SENSOR_IMU_FRAME=head_camera_imu_frame

# Browser video side channel.
# This keeps human-facing RGB video out of rosbridge. The compute PC should run
# MediaMTX; the Pi publishes H.264 RTSP into it, and the browser reads WebRTC.
DEPTH_SENSOR_RTSP_ENABLE=false
DEPTH_SENSOR_RTSP_URL=rtsp://192.168.0.10:8554/xlerobot_head
DEPTH_SENSOR_RTSP_FPS=15
DEPTH_SENSOR_RTSP_BITRATE_KBPS=3000
DEPTH_SENSOR_RTSP_TRANSPORT=tcp

# USB camera RTSP side channels for human-facing video.
ENABLE_USB_CAMERA_RTSP=true
USB_CAMERA_RTSP_CAMERAS=base,wrist_left,wrist_right
USB_CAMERA_WIDTH=640
USB_CAMERA_HEIGHT=480
USB_CAMERA_FPS=15
USB_CAMERA_RTSP_BITRATE_KBPS=1500
BASE_CAMERA_DEVICE=/dev/v4l/by-path/platform-xhci-hcd.1-usb-0:1.3:1.0-video-index0
BASE_CAMERA_ROTATE_DEG=0
BASE_CAMERA_RTSP_URL=rtsp://192.168.0.10:8554/xlerobot_base
WRIST_LEFT_CAMERA_DEVICE=/dev/v4l/by-path/platform-xhci-hcd.1-usb-0:1.4:1.0-video-index0
WRIST_LEFT_CAMERA_ROTATE_DEG=180
WRIST_LEFT_CAMERA_RTSP_URL=rtsp://192.168.0.10:8554/xlerobot_wrist_left
WRIST_RIGHT_CAMERA_DEVICE=/dev/v4l/by-path/platform-xhci-hcd.0-usb-0:1:1.0-video-index0
WRIST_RIGHT_CAMERA_ROTATE_DEG=180
WRIST_RIGHT_CAMERA_RTSP_URL=rtsp://192.168.0.10:8554/xlerobot_wrist_right

# Optional compressed camera.
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=320
CAMERA_HEIGHT=240
CAMERA_RATE_HZ=10
CAMERA_JPEG_QUALITY=60
CAMERA_FRAME=camera_optical_frame
CAMERA_HFOV_DEG=70.0
